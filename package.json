{
  "name": "shortener",
  "version": "0.1.0",
  "private": true,
  "description": "ShortLink — URL shortening service (Indicina senior engineering assessment)",
  "engines": {
    "node": ">=20.9.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "npm run dev --workspace @shortener/api",
    "dev:web": "npm run dev --workspace @shortener/web",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.5.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": "prettier --write",
    "*.{json,md,css}": "prettier --write"
  }
}
