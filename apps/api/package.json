    "@types/express": "^5.0.3",
    "@types/node": "^20",
    "@types/supertest": "^7.2.1",
    "@vitest/coverage-v8": "^3.2.7",
    "eslint": "^9",
    "supertest": "^7.2.2",
    "tsx": "^4.20.3",
    "typescript": "^5",
    "typescript-eslint": "^8.35.0",
    "vitest": "^3.2.4"
  }
}
